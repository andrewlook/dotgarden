# Package-local gitignore for the dotgarden source tree. Separate from the
# parent dotfiles repo's .gitignore so that when this dir is subtree-pushed
# to andrewlook/dotgarden, published sdists contain only package-relevant
# ignore patterns.
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
dist/
build/
.venv/
