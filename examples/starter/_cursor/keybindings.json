[
    // Cursor editor keybindings — example checked-in copy.
    // Lives under ~/Library/Application Support/Cursor/User/keybindings.json
    // on a real machine; the registry maps this repo path → that macOS path.
    {
        "key": "cmd+shift+p",
        "command": "workbench.action.showCommands"
    },
    {
        "key": "cmd+k cmd+s",
        "command": "workbench.action.openGlobalKeybindings"
    }
]
